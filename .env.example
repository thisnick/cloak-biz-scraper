# cloak-biz-scraper — local development only.
#
# Copy to `.env` and fill in. `.env` is gitignored and MUST stay that way.
#
# The DEPLOYED app needs none of this. Railway sets exactly one variable —
# APP_SECRET — and everything else is configured in the web UI and stored on the
# volume. The variables below only exist so a local dev run can skip the UI:
# each one SEEDS the matching setting on FIRST BOOT ONLY. After that, the volume
# is the source of truth and editing these has no effect.

# --- Required -----------------------------------------------------------------
# Login + token signing. Generate one: python -c "import secrets;print(secrets.token_urlsafe(32))"
#
# Unlike the seeds below, this one has a recovery path, because the UI can rotate
# it and a forgotten rotated secret would otherwise brick the deployment with no
# terminal to fix it from. The volume's copy is authoritative; this only seeds it
# on first boot.
APP_SECRET=

# Forgot the secret you rotated to? Set a new APP_SECRET above, set this to true,
# and restart: the next boot adopts the new value. It is consumed once, so
# leaving it set does NOT keep reverting later rotations — but tidy it up anyway.
APP_SECRET_RESET=

# --- First-boot seeds (optional) ----------------------------------------------
# Optional CloakBrowser Pro licence. Leave blank to deliberately use the public
# build (fewer bypasses; not tested by us against listing sites). The selected
# Chromium downloads on demand into the volume — never into the image.
CLOAKBROWSER_LICENSE_KEY=
# Optional version pin. Empty = track latest. Must be a full numeric Chromium
# version, e.g. 148.0.7778.215.2 — a malformed pin fails fast.
CLOAKBROWSER_VERSION=

# Evomi residential proxy.
EVOMI_PROXY_USER=
EVOMI_PROXY_PASSWORD=
EVOMI_PROXY_HOST=
EVOMI_PROXY_PORT=
EVOMI_DEFAULT_COUNTRY=US
EVOMI_DEFAULT_REGION=california

# Browser pool. Each running browser uses roughly 0.5-1 GB.
MAX_INSTANCES=4
INTERACTIVE_RESERVE=1

# Notion. Create an integration at https://www.notion.so/my-integrations, then
# SHARE your database or page with it from Notion's ••• menu — an unshared
# database is invisible to the API and reported as "not found".
NOTION_API_TOKEN=
# The database to sync into. Normally chosen in the UI (picked from a list, or
# created explicitly). Seeding it here is for CI; the app never picks one itself.
NOTION_DB_ID=

# --- Not used by the app ------------------------------------------------------
# Deploy tooling only; never read at runtime.
RAILWAY_TOKEN=
