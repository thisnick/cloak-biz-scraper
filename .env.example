# cloak-biz-scraper — local development only.
#
# Copy to `.env` and fill in. `.env` is gitignored and MUST stay that way.
#
# The DEPLOYED app needs none of this. Railway sets exactly one variable —
# APP_SECRET — and everything else is configured in the web UI and stored on the
# volume. The variables below only exist so a local dev run can skip the UI:
# each one SEEDS the matching setting on FIRST BOOT ONLY. After that, the volume
# is the source of truth and editing these has no effect.

# --- Required -----------------------------------------------------------------
# Login + token signing. Generate one: python -c "import secrets;print(secrets.token_urlsafe(32))"
APP_SECRET=

# --- First-boot seeds (optional) ----------------------------------------------
# CloakBrowser Pro license. The Chromium binary is downloaded on demand into the
# volume by the cloakbrowser package itself — never baked into the image.
CLOAKBROWSER_LICENSE_KEY=
# Optional version pin. Empty = track latest. Must be a full numeric Chromium
# version, e.g. 148.0.7778.215.2 — a malformed pin fails fast.
CLOAKBROWSER_VERSION=

# Evomi residential proxy.
EVOMI_PROXY_USER=
EVOMI_PROXY_PASSWORD=
EVOMI_PROXY_HOST=
EVOMI_PROXY_PORT=
EVOMI_DEFAULT_COUNTRY=US
EVOMI_DEFAULT_REGION=california

# Browser pool. Each running browser uses roughly 0.5-1 GB.
MAX_INSTANCES=4
INTERACTIVE_RESERVE=1

# --- Later steps --------------------------------------------------------------
# Notion integration token (used from Step 2 on).
NOTION_API_TOKEN=

# --- Not used by the app ------------------------------------------------------
# Deploy tooling only; never read at runtime.
RAILWAY_TOKEN=
